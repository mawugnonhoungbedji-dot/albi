---
import '../index.css';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  pageUrl?: string;
}

const { 
  title, 
  description = "Soutenez Albi International, l'ONG beninoise qui defend les droits des enfants albinos au Benin. Cremes solaires SPF 50+, kits scolaires adaptes et inclusion sociale.",
  pageUrl = "https://albi-international-benin.org"
} = Astro.props;

const jsonLdNgo = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "NGO",
  "@id": "https://albi-international-benin.org/#organization",
  "name": "Albi International Benin",
  "alternateName": "Albi International",
  "description": "ONG beninoise fondee en 2017 par Carine HOUNGUE, elle-meme atteinte d'albinisme, pour defendre les droits des personnes albinos au Benin : distribution de cremes solaires SPF 50+, kits scolaires adaptes, lutte contre les mutilations rituelles et l'exclusion sociale.",
  "url": "https://albi-international-benin.org",
  "logo": {
    "@type": "ImageObject",
    "url": "https://albi-international-benin.org/images/Logo.webp",
    "width": 400,
    "height": 400
  },
  "image": "https://albi-international-benin.org/images/og-share.webp",
  "foundingDate": "2017-06",
  "founder": {
    "@type": "Person",
    "name": "Carine HOUNGUE",
    "jobTitle": "Fondatrice & Directrice Generale",
    "description": "Atteinte d'albinisme depuis sa naissance, Carine HOUNGUE a cree Albi International en juin 2017 apres le deces de sa soeur d'un melanome evitable. Defenseure des droits des albinos en Afrique de l'Ouest.",
    "nationality": "Beninoise"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Cotonou",
    "addressRegion": "Littoral",
    "addressCountry": "BJ"
  },
  "areaServed": [
    { "@type": "Country", "name": "Benin" },
    { "@type": "AdministrativeArea", "name": "Afrique de l'Ouest" }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+229-97-49-45-91",
    "contactType": "customer service",
    "availableLanguage": ["French"]
  },
  "sameAs": [
    "https://wa.me/22997494591"
  ],
  "knowsAbout": [
    "Albinisme",
    "Droits des personnes atteintes d'albinisme",
    "Protection solaire SPF 50+",
    "Inclusion educative au Benin",
    "Lutte contre les mutilations rituelles en Afrique"
  ]
});

const jsonLdFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qu'est-ce que l'albinisme et quels sont ses risques en Afrique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'albinisme est une condition genetique hereditaire caracterisee par l'absence ou la tres faible production de melanine. En Afrique subsaharienne, sans protection solaire SPF 50+, les personnes atteintes developpent frequemment des melanomes agressifs des l'adolescence. L'albinisme n'est ni contagieux, ni mystique, ni lie a une malediction."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle creme solaire est recommandee pour les enfants albinos en Afrique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Albi International preconise exclusivement des ecrans mineraux ou filtres chimiques d'indice SPF 50+ minimum, sans parfum ni alcool, adaptes a la peau pediatrique. Ces protections doivent etre reappliquees toutes les 2 heures lors des expositions au soleil equatorial beninois."
      }
    },
    {
      "@type": "Question",
      "name": "Comment parrainer un enfant atteint d'albinisme au Benin ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le parrainage a 45 euros finance integralement le kit annuel d'un ecolier albinos : cremes solaires SPF 50+, lunettes UV certifiees, loupe de lecture ergonomique, chapeau a larges bords et cahiers a gros caracteres. Le parrain recoit chaque trimestre un rapport personnalise avec les notes scolaires et l'etat de sante de l'enfant suivi."
      }
    },
    {
      "@type": "Question",
      "name": "Comment m'assurer que mon don arrive bien aux enfants au Benin ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Albi International pratique une transparence absolue : chaque trimestre, un rapport logistique complet avec photos nominatives de distribution est transmis aux donateurs. 100% des dons sont affectes a l'achat et a l'acheminement des lots au Benin."
      }
    },
    {
      "@type": "Question",
      "name": "L'albinisme est-il lie a des croyances rituelles en Afrique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non. L'albinisme est une condition genetique hereditaire d'origine purement clinique. Pourtant, dans certaines communautes d'Afrique subsaharienne, des superstitions attribuent des pouvoirs magiques aux membres des personnes albinos, motivant des violences rituelles documentees par l'ONU. Albi International combat ces mythes par l'education scientifique."
      }
    },
    {
      "@type": "Question",
      "name": "Qu'est-ce que la Journee Internationale de Sensibilisation a l'Albinisme (JISA) ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La JISA est celebree chaque 13 juin depuis la resolution A/RES/69/170 de l'Assemblee Generale des Nations Unies (2014). Au Benin, Albi International en fait son evenement phare annuel : distribution gratuite de cremes solaires SPF 50+ et campagnes de sensibilisation scolaires."
      }
    },
    {
      "@type": "Question",
      "name": "Quels problemes visuels touchent les personnes atteintes d'albinisme ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'albinisme entraine structurellement un nystagmus (mouvements oculaires involontaires), un strabisme prononce et une acuite visuelle tres reduite. Sans materiel adapte (loupes de lecture, lunettes filtrantes UV, cahiers a gros caracteres), les enfants albinos sont prives de leur droit a l'education."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il des frais preleves sur mes dons a Albi International ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aucun intermediaire. 100% des dons materiels ou financiers sont affectes directement a l'achat et a la logistique d'acheminement des kits au Benin, sous la supervision de nos coordinateurs terrain."
      }
    }
  ]
});

const jsonLdEvent = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Journee Internationale de Sensibilisation a l'Albinisme (JISA) - Benin 2026",
  "description": "Evenement annuel d'Albi International au Benin : distribution gratuite de cremes solaires SPF 50+ aux familles vulnerables, campagnes de sensibilisation scolaire et plaidoyer pour les droits des personnes atteintes d'albinisme. Resolution ONU A/RES/69/170.",
  "startDate": "2026-06-13",
  "endDate": "2026-06-13",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": "Cotonou & Porto-Novo, Benin",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cotonou",
      "addressCountry": "BJ"
    }
  },
  "organizer": {
    "@type": "NGO",
    "@id": "https://albi-international-benin.org/#organization",
    "name": "Albi International Benin",
    "url": "https://albi-international-benin.org"
  },
  "isAccessibleForFree": true,
  "inLanguage": "fr"
});
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/webp" href="/images/Logo.webp" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={pageUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://albi-international-benin.org/images/og-share.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Albi International - Defendre les droits des albinos au Benin" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Albi International Benin" />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://albi-international-benin.org/images/og-share.webp" />

    <!-- JSON-LD : NGO + FAQPage + Event (injected via frontmatter to avoid encoding issues) -->
    <script type="application/ld+json" set:html={jsonLdNgo} />
    <script type="application/ld+json" set:html={jsonLdFaq} />
    <script type="application/ld+json" set:html={jsonLdEvent} />
  </head>
  <body>
    <slot />
    <SpeedInsights />
  </body>
</html>
